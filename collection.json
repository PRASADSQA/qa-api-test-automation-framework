{
  "info": {
    "_postman_id": "d08a82b2-fc5d-452a-a28c-423ed8d07d72",
    "name": "QA API Automation Framework",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "6398545",
    "_collection_link": "https://go.postman.co/collection/6398545-d08a82b2-fc5d-452a-a28c-423ed8d07d72?source=collection_link"
  },
  "item": [
    {
      "name": "Retrieve Posts",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Validate userId matches environment\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.userId).to.eql(parseInt(pm.environment.get(\"user_id\")));\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/posts/{{post_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "posts",
            "{{post_id}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create Post",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Store created post ID\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.environment.set(\"created_post_id\", jsonData.id);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.environment.set(\"random_title\", \"QA Test \" + Math.floor(Math.random() * 1000));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"title\": \"{{random_title}}\",\r\n  \"body\": \"Learning API testing\",\r\n  \"userId\": {{user_id}}\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/posts",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "posts"
          ]
        }
      },
      "response": []
    }
  ]
}